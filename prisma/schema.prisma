generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ChallengeType {
  CLOSEST_TO_PIN
  LONGEST_DRIVE
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum EntryStatus {
  PENDING_PAYMENT
  PAID
  READY
  IN_PROGRESS
  COMPLETED
  DISQUALIFIED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PrizeStatus {
  AVAILABLE
  AWARDED
  PAID_OUT
}

enum SimulatorProvider {
  TRUGOLF_APOGEE_E6
  E6_CONNECT
  FLIGHTSCOPE_E6
  MANUAL
  OTHER
}

enum SimulatorSessionStatus {
  CREATED
  OPERATOR_READY
  LAUNCHED
  IN_PROGRESS
  RESULT_PENDING
  VERIFIED
  SYNCED
  CANCELLED
}

enum SimulatorResultSource {
  MANUAL_ENTRY
  SCREENSHOT
  CSV_IMPORT
  LOCAL_AGENT
  VENDOR_API
}

enum SimulatorResultStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
  SYNCED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries  Entry[]
  payments Payment[]
}

model Location {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  city      String?
  state     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bays       Bay[]
  challenges Challenge[]
  simulatorSessions SimulatorSession[]
}

model Bay {
  id         String   @id @default(cuid())
  name       String
  qrCodeUrl  String?
  isActive   Boolean  @default(true)
  locationId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location   Location    @relation(fields: [locationId], references: [id])
  challenges Challenge[]
  entries    Entry[]
  simulatorSessions SimulatorSession[]

  @@unique([locationId, name])
}

model Challenge {
  id          String          @id @default(cuid())
  name        String
  type        ChallengeType
  status      ChallengeStatus @default(DRAFT)
  entryFee    Int             @default(2000)
  startsAt    DateTime?
  endsAt      DateTime?
  locationId  String
  bayId       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  location    Location      @relation(fields: [locationId], references: [id])
  bay         Bay?          @relation(fields: [bayId], references: [id])
  entries     Entry[]
  leaderboard Leaderboard?
  prizes      Prize[]
  simulatorSessions SimulatorSession[]
}

model Entry {
  id          String      @id @default(cuid())
  status      EntryStatus @default(PENDING_PAYMENT)
  entryNumber Int?
  userId      String
  challengeId String
  bayId       String?
  paymentId   String?     @unique
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])
  bay       Bay?      @relation(fields: [bayId], references: [id])
  payment   Payment?  @relation(fields: [paymentId], references: [id])
  shots     Shot[]
  simulatorSessions SimulatorSession[]

  @@index([challengeId, status])
}

model Shot {
  id                String   @id @default(cuid())
  entryId           String
  shotNumber        Int
  carryYards        Decimal? @db.Decimal(7, 2)
  totalYards        Decimal? @db.Decimal(7, 2)
  distanceToPinInch Decimal? @db.Decimal(8, 2)
  isHoleInOne       Boolean  @default(false)
  notes             String?
  enteredBy         String?
  createdAt         DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id])

  @@unique([entryId, shotNumber])
}

model Leaderboard {
  id          String   @id @default(cuid())
  challengeId String   @unique
  standings   Json
  updatedAt   DateTime @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id])
}

model Payment {
  id                     String        @id @default(cuid())
  userId                 String
  amount                 Int
  currency               String        @default("usd")
  status                 PaymentStatus @default(PENDING)
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId   String?       @unique
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  entry Entry?
}

model Prize {
  id          String      @id @default(cuid())
  challengeId String
  name        String
  value       Int?
  status      PrizeStatus @default(AVAILABLE)
  winnerId    String?
  awardedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id])
}

model SimulatorDevice {
  id                  String            @id @default(cuid())
  provider            SimulatorProvider @default(TRUGOLF_APOGEE_E6)
  venueName           String
  bayName             String
  softwareName        String?
  softwareVersion     String?
  launchMonitorModel  String?
  launchMonitorSerial String?
  firmwareVersion     String?
  operatorPcName      String?
  notes               String?
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  sessions SimulatorSession[]

  @@index([provider, venueName, bayName])
}

model SimulatorSession {
  id                 String                 @id @default(cuid())
  pin2WinSessionId   String                 @unique
  provider           SimulatorProvider      @default(TRUGOLF_APOGEE_E6)
  status             SimulatorSessionStatus @default(CREATED)
  challengeType      ChallengeType
  playerAlias        String?
  operatorName       String?
  venueName          String?
  bayName            String?
  course             String?
  hole               Int?
  teeBox             String?
  pinLocation        String?
  attempts           Int?
  playTimeMinutes    Int?
  e6SessionName      String?
  e6SessionId        String?
  externalSessionId  String?
  syncEligible       Boolean                @default(false)
  launchInstructions Json?
  rawMetadata        Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  launchedAt         DateTime?
  completedAt        DateTime?

  deviceId    String?
  locationId  String?
  bayId       String?
  challengeId String?
  entryId     String?

  device    SimulatorDevice? @relation(fields: [deviceId], references: [id])
  location  Location?        @relation(fields: [locationId], references: [id])
  bay       Bay?             @relation(fields: [bayId], references: [id])
  challenge Challenge?       @relation(fields: [challengeId], references: [id])
  entry     Entry?           @relation(fields: [entryId], references: [id])
  results   SimulatorResult[]

  @@index([status, provider])
  @@index([challengeType, createdAt])
}

model SimulatorResult {
  id                  String                @id @default(cuid())
  sessionId           String
  source              SimulatorResultSource @default(MANUAL_ENTRY)
  status              SimulatorResultStatus @default(PENDING_REVIEW)
  challengeType       ChallengeType
  playerAlias         String?
  rawResult           String
  resultUnit          String
  totalYards          Decimal?              @db.Decimal(7, 2)
  distanceToPinInches Decimal?              @db.Decimal(8, 2)
  evidenceUrl         String?
  verifierName        String?
  notes               String?
  rawPayload          Json?
  createdAt           DateTime              @default(now())
  verifiedAt          DateTime?
  syncedAt            DateTime?

  session SimulatorSession @relation(fields: [sessionId], references: [id])

  @@index([challengeType, status])
  @@index([sessionId, createdAt])
}
